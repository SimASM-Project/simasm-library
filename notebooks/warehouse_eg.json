      "description": "Start Pick A"
    },
    {
      "name": "StartPickB",
      "state_change": "Q2 := Q2 - 1; S2 := S2 - 1",
      "description": "Start Pick B"
    },
    {
      "name": "FinishPickA",
      "state_change": "S1 := S1 + 1",
      "description": "Finish Pick A"
    },
    {
      "name": "FinishPickB",
      "state_change": "S2 := S2 + 1",
      "description": "Finish Pick B"
    },
