    },
    {
      "name": "StartRelease",
      "state_change": "Q6 := Q6 - 1; S6 := S6 - 1",
      "description": "Start Release"
    },
    {
      "name": "FinishRelease",
      "state_change": "S6 := S6 + 1; departures := departures + 1",
      "description": "Finish Release"
