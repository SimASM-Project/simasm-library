        let scheduled_start_10 = new Event
        event_rule(scheduled_start_10) := "event_start_10"
        event_scheduled_time(scheduled_start_10) := sim_clocktime
        event_parameters(scheduled_start_10) := []
        lib.add(future_event_list, scheduled_start_10)
    endif

    if server_count_11 < service_capacity then
