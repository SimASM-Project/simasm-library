    queue_count_1 + server_count_1 + queue_count_2 + server_count_2 + queue_count_3 + server_count_3 + queue_count_4 + server_count_4 + queue_count_5 + server_count_5 + queue_count_6 + server_count_6 + queue_count_7 + server_count_7 + queue_count_8 + server_count_8 + queue_count_9 + server_count_9 + queue_count_10 + server_count_10 + queue_count_11 + server_count_11 + queue_count_12 + server_count_12 + queue_count_13 + server_count_13 + queue_count_14 + server_count_14 + queue_count_15 + server_count_15

