// =============================================================================
// Event Graph Model: feedback_15_eg
// =============================================================================
// Feedback 15-Queue using Event Graph formalism - 15 stations in tandem with 50% feedback
// Generated: 2026-02-02 17:09:25
// Formalism: Event Graph (Schruben 1983)
// Algorithm: Next-Event Time-Advance (Law 2013)

// =============================================================================
// IMPORT LIBRARIES
// =============================================================================

import Random as rnd
import Stdlib as lib

// =============================================================================
// DOMAIN DECLARATIONS
// =============================================================================

// Base object domain
domain Object

// Event domain
domain Event

// =============================================================================
// CONSTANT DECLARATIONS
// =============================================================================

const service_capacity: Nat  // Number of servers per station
const iat_mean: Real  // Inter-arrival time mean
const ist_mean: Real  // Service time mean per station
const feedback_prob: Real  // Probability of feedback to station 1
const sim_end_time: Real  // Simulation end time

// =============================================================================
// DYNAMIC VARIABLE DECLARATIONS - STATES space
// =============================================================================

// Simulation clock and event list
var sim_clocktime: Real
var future_event_list: List<Event>
var current_event: Event

// State variables (STATES)
var queue_count_1: Nat  // Number in queue at station 1
var server_count_1: Nat  // Number being served at station 1
var queue_count_2: Nat  // Number in queue at station 2
var server_count_2: Nat  // Number being served at station 2
var queue_count_3: Nat  // Number in queue at station 3
var server_count_3: Nat  // Number being served at station 3
