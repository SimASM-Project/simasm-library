var service_time_11: rnd.exponential(ist_mean) as "service_11"
var service_time_12: rnd.exponential(ist_mean) as "service_12"
var service_time_13: rnd.exponential(ist_mean) as "service_13"
var service_time_14: rnd.exponential(ist_mean) as "service_14"
var service_time_15: rnd.exponential(ist_mean) as "service_15"
var feedback_decision: rnd.uniform(0.0, 1.0) as "feedback"

