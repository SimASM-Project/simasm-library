rule event_finish_15() =
    // State transition: server_count_15 := server_count_15 - 1
    server_count_15 := server_count_15 - 1

    // Process scheduling edges E_s(G)
    if queue_count_15 > 0 and server_count_15 < service_capacity then
        let scheduled_start_15 = new Event
        event_rule(scheduled_start_15) := "event_start_15"
        event_scheduled_time(scheduled_start_15) := sim_clocktime
        event_parameters(scheduled_start_15) := []
        lib.add(future_event_list, scheduled_start_15)
    endif

    let scheduled_attempt__to__depart = new Event
    event_rule(scheduled_attempt__to__depart) := "event_attempt__to__depart"
    event_scheduled_time(scheduled_attempt__to__depart) := sim_clocktime
    event_parameters(scheduled_attempt__to__depart) := []
    lib.add(future_event_list, scheduled_attempt__to__depart)

endrule

// -----------------------------------------------------------------------------
// Attempt_To_Depart Event - f_Attempt_To_Depart
// -----------------------------------------------------------------------------
// Probabilistic departure/feedback decision

rule event_attempt__to__depart() =
    // Process scheduling edges E_s(G)
    // Probabilistic feedback decision: feedback with probability feedback_prob
    let fb_rand = feedback_decision

    if fb_rand < feedback_prob then
        // Feedback: return to queue at station 1
        queue_count_1 := queue_count_1 + 1
        if server_count_1 < service_capacity then
            let scheduled_start_1 = new Event
            event_rule(scheduled_start_1) := "event_start_1"
            event_scheduled_time(scheduled_start_1) := sim_clocktime
            event_parameters(scheduled_start_1) := []
            lib.add(future_event_list, scheduled_start_1)
        endif
    endif

    if fb_rand >= feedback_prob then
        // No feedback: depart
        let scheduled_depart = new Event
        event_rule(scheduled_depart) := "event_depart"
        event_scheduled_time(scheduled_depart) := sim_clocktime
        event_parameters(scheduled_depart) := []
        lib.add(future_event_list, scheduled_depart)
    endif

endrule

// -----------------------------------------------------------------------------
// Depart Event - f_Depart
// -----------------------------------------------------------------------------
// Customer departs the system

rule event_depart() =
    // State transition: departure_count := departure_count + 1
    departure_count := departure_count + 1

endrule

// =============================================================================
// NEXT-EVENT TIME-ADVANCE ALGORITHM
// =============================================================================

// -----------------------------------------------------------------------------
// Initialization Routine
// -----------------------------------------------------------------------------
// Set STATE := STATE_0, FEL := FEL_0

rule initialisation_routine() =
    // Schedule initial Arrive event
    let init_event_0 = new Event
    event_rule(init_event_0) := "event_arrive"
    event_scheduled_time(init_event_0) := sim_clocktime + interarrival_time
    event_parameters(init_event_0) := []
    lib.add(future_event_list, init_event_0)

endrule

// -----------------------------------------------------------------------------
// Timing Routine
// -----------------------------------------------------------------------------
// Pop earliest event from FEL, advance clock to event time

rule timing_routine() =
    // Sort FEL by (scheduled_time, -priority)
    lib.sort(future_event_list, "event_scheduled_time")

    if lib.length(future_event_list) > 0 then
        // Remove next event from FEL
        let next_event = lib.pop(future_event_list)

        // Advance simulation clock
        sim_clocktime := event_scheduled_time(next_event)

        // Store for event routine dispatch
        current_event := next_event
    endif
endrule

// -----------------------------------------------------------------------------
// Event Routine
// -----------------------------------------------------------------------------
// Dispatch to event-specific rule using lib.apply_rule

rule event_routine() =
    let r = event_rule(current_event)
    let params = event_parameters(current_event)
    lib.apply_rule(r, params)
endrule

// =============================================================================
// INITIAL STATE - STATE_0
// =============================================================================

init:
    // Parameters
    service_capacity := 5
    iat_mean := 1.25
    ist_mean := 1.0
    feedback_prob := 0.5
    sim_end_time := 10000.0

    // Simulation state
    sim_clocktime := 0.0
    future_event_list := []

    // Initial state variables STATE_0
    queue_count_1 := 0
    server_count_1 := 0
    queue_count_2 := 0
    server_count_2 := 0
    queue_count_3 := 0
    server_count_3 := 0
    queue_count_4 := 0
    server_count_4 := 0
    queue_count_5 := 0
    server_count_5 := 0
    queue_count_6 := 0
    server_count_6 := 0
    queue_count_7 := 0
    server_count_7 := 0
    queue_count_8 := 0
    server_count_8 := 0
    queue_count_9 := 0
    server_count_9 := 0
    queue_count_10 := 0
    server_count_10 := 0
    queue_count_11 := 0
    server_count_11 := 0
    queue_count_12 := 0
    server_count_12 := 0
    queue_count_13 := 0
    server_count_13 := 0
    queue_count_14 := 0
    server_count_14 := 0
    queue_count_15 := 0
    server_count_15 := 0
    load_id_counter := 0
    departure_count := 0
endinit

// =============================================================================
// MAIN RULE
// =============================================================================

main rule main =
    // Initialize on first step
    if sim_clocktime == 0.0 and lib.length(future_event_list) == 0 then
        initialisation_routine()
    endif

    // Run while FEL not empty and time not exceeded
    if lib.length(future_event_list) > 0 and sim_clocktime < sim_end_time then
        timing_routine()
        event_routine()
    endif
endrule

