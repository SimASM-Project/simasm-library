var queue_count_12: Nat  // Number in queue at station 12
var server_count_12: Nat  // Number being served at station 12
var queue_count_13: Nat  // Number in queue at station 13
var server_count_13: Nat  // Number being served at station 13
var queue_count_14: Nat  // Number in queue at station 14
var server_count_14: Nat  // Number being served at station 14
var queue_count_15: Nat  // Number in queue at station 15
var server_count_15: Nat  // Number being served at station 15
var load_id_counter: Nat
var departure_count: Nat

// =============================================================================
// RANDOM STREAM VARIABLES - Edge delay functions T
// =============================================================================

var interarrival_time: rnd.exponential(iat_mean) as "arrivals"
var service_time_1: rnd.exponential(ist_mean) as "service_1"
var service_time_2: rnd.exponential(ist_mean) as "service_2"
var service_time_3: rnd.exponential(ist_mean) as "service_3"
var service_time_4: rnd.exponential(ist_mean) as "service_4"
var service_time_5: rnd.exponential(ist_mean) as "service_5"
var service_time_6: rnd.exponential(ist_mean) as "service_6"
var service_time_7: rnd.exponential(ist_mean) as "service_7"
