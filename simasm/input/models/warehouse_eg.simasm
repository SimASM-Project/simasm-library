// =============================================================================
// QUEUE EVENTS
// =============================================================================

// -----------------------------------------------------------------------------
// Queue_Q1: Enter queue for Pick Zone A
// State Transition: Q1 := Q1 + 1
// -----------------------------------------------------------------------------

rule queue_q1(load: Load) =
    // State transition
    queue_length(q1) := queue_length(q1) + 1
    lib.add(queue_contents(q1), load)

    // Schedule: Queue_Q1 -> Attempt_PickA (immediate)
    let attempt_event = new AttemptServiceEvent
    event_rule(attempt_event) := "attempt_pick_a"
    event_scheduled_time(attempt_event) := sim_clocktime
    event_priority(attempt_event) := 5  // PickZoneA priority
    event_parameters(attempt_event) := [load]
    lib.add(future_event_list, attempt_event)
endrule

// -----------------------------------------------------------------------------
// Queue_Q2: Enter queue for Pick Zone B
// State Transition: Q2 := Q2 + 1
// -----------------------------------------------------------------------------

rule queue_q2(load: Load) =
    queue_length(q2) := queue_length(q2) + 1
    lib.add(queue_contents(q2), load)

    let attempt_event = new AttemptServiceEvent
    event_rule(attempt_event) := "attempt_pick_b"
    event_scheduled_time(attempt_event) := sim_clocktime
    event_priority(attempt_event) := 6  // PickZoneB priority
    event_parameters(attempt_event) := [load]
    lib.add(future_event_list, attempt_event)
endrule

// -----------------------------------------------------------------------------
// Queue_Q3: Enter queue for Label
// State Transition: Q3 := Q3 + 1
