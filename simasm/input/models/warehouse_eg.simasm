        lib.add(future_event_list, start_event)
    endif
endrule

// =============================================================================
// SERVICE START EVENTS
// =============================================================================

// -----------------------------------------------------------------------------
// Pick_ZA: Start service at Pick Zone A
// State Transition: S1 := S1 - 1; Q1 := Q1 - 1
// -----------------------------------------------------------------------------

rule pick_za(load: Load) =
    // State transitions
    servers_available(server_pick_a) := servers_available(server_pick_a) - 1
    servers_busy(server_pick_a) := servers_busy(server_pick_a) + 1
    queue_length(q1) := queue_length(q1) - 1

    // Remove from queue, add to service
    lib.remove(queue_contents(q1), load)
    lib.add(in_service(server_pick_a), load)
    service_start_time(load) := sim_clocktime

    // Schedule: Pick_ZA -> Finish_PickA (delay t^s1)
    let finish_event = new ServiceFinishEvent
    event_rule(finish_event) := "finish_pick_a"
    event_scheduled_time(finish_event) := sim_clocktime + service_time_s1
    event_priority(finish_event) := 5  // PickZoneA priority
    event_parameters(finish_event) := [load]
    lib.add(future_event_list, finish_event)
endrule

// -----------------------------------------------------------------------------
// Pick_ZB: Start service at Pick Zone B
// State Transition: S2 := S2 - 1; Q2 := Q2 - 1
// -----------------------------------------------------------------------------

rule pick_zb(load: Load) =
    servers_available(server_pick_b) := servers_available(server_pick_b) - 1
    servers_busy(server_pick_b) := servers_busy(server_pick_b) + 1
    queue_length(q2) := queue_length(q2) - 1

    lib.remove(queue_contents(q2), load)
    lib.add(in_service(server_pick_b), load)
    service_start_time(load) := sim_clocktime

    let finish_event = new ServiceFinishEvent
    event_rule(finish_event) := "finish_pick_b"
    event_scheduled_time(finish_event) := sim_clocktime + service_time_s2
    event_priority(finish_event) := 6  // PickZoneB priority
    event_parameters(finish_event) := [load]
    lib.add(future_event_list, finish_event)
endrule

// -----------------------------------------------------------------------------
// Label: Start service at Label station
// State Transition: S3 := S3 - 1; Q3 := Q3 - 1
// -----------------------------------------------------------------------------

rule label(load: Load) =
    servers_available(server_label) := servers_available(server_label) - 1
    servers_busy(server_label) := servers_busy(server_label) + 1
    queue_length(q3) := queue_length(q3) - 1

    lib.remove(queue_contents(q3), load)
    lib.add(in_service(server_label), load)
    service_start_time(load) := sim_clocktime

    let finish_event = new ServiceFinishEvent
    event_rule(finish_event) := "finish_label"
    event_scheduled_time(finish_event) := sim_clocktime + service_time_s3
    event_priority(finish_event) := 7  // Label priority
    event_parameters(finish_event) := [load]
    lib.add(future_event_list, finish_event)
endrule

// -----------------------------------------------------------------------------
// Scan: Start service at Scan station
// State Transition: S4 := S4 - 1; Q4 := Q4 - 1
// -----------------------------------------------------------------------------

rule scan(load: Load) =
    servers_available(server_scan) := servers_available(server_scan) - 1
    servers_busy(server_scan) := servers_busy(server_scan) + 1
    queue_length(q4) := queue_length(q4) - 1

    lib.remove(queue_contents(q4), load)
    lib.add(in_service(server_scan), load)
    service_start_time(load) := sim_clocktime

    let finish_event = new ServiceFinishEvent
    event_rule(finish_event) := "finish_scan"
    event_scheduled_time(finish_event) := sim_clocktime + service_time_s4
    event_priority(finish_event) := 8  // Scan priority
    event_parameters(finish_event) := [load]
    lib.add(future_event_list, finish_event)
endrule

// -----------------------------------------------------------------------------
// Pack: Start service at Pack station
// State Transition: S5 := S5 - 1; Q5 := Q5 - 1
// -----------------------------------------------------------------------------

rule pack(load: Load) =
    servers_available(server_pack) := servers_available(server_pack) - 1
    servers_busy(server_pack) := servers_busy(server_pack) + 1
    queue_length(q5) := queue_length(q5) - 1

    lib.remove(queue_contents(q5), load)
    lib.add(in_service(server_pack), load)
    service_start_time(load) := sim_clocktime

    let finish_event = new ServiceFinishEvent
    event_rule(finish_event) := "finish_pack"
    event_scheduled_time(finish_event) := sim_clocktime + service_time_s5
    event_priority(finish_event) := 9  // Pack priority
    event_parameters(finish_event) := [load]
    lib.add(future_event_list, finish_event)
endrule

// -----------------------------------------------------------------------------
// Release: Start service at Release station
// State Transition: S6 := S6 - 1; Q6 := Q6 - 1
// -----------------------------------------------------------------------------

rule release(load: Load) =
    servers_available(server_release) := servers_available(server_release) - 1
    servers_busy(server_release) := servers_busy(server_release) + 1
    queue_length(q6) := queue_length(q6) - 1

    lib.remove(queue_contents(q6), load)
    lib.add(in_service(server_release), load)
    service_start_time(load) := sim_clocktime

    let finish_event = new ServiceFinishEvent
    event_rule(finish_event) := "finish_release"
    event_scheduled_time(finish_event) := sim_clocktime + service_time_s6
    event_priority(finish_event) := 10  // Release priority
    event_parameters(finish_event) := [load]
    lib.add(future_event_list, finish_event)
endrule

// =============================================================================
// SERVICE FINISH EVENTS
// =============================================================================

// -----------------------------------------------------------------------------
// Finish_PickA: Finish service at Pick Zone A
// State Transition: S1 := S1 + 1
// Scheduling: -> Attempt_PickA (immediate), -> Attempt_Q3 (immediate)
// -----------------------------------------------------------------------------

rule finish_pick_a(load: Load) =
    // State transition
    servers_available(server_pick_a) := servers_available(server_pick_a) + 1
    servers_busy(server_pick_a) := servers_busy(server_pick_a) - 1

    // Remove from service
    lib.remove(in_service(server_pick_a), load)

    // Accumulate queue time statistics
    let time_in_queue = service_start_time(load) - arrival_time(load)
    total_time_in_queue(q1) := total_time_in_queue(q1) + time_in_queue

    // Schedule: Finish_PickA -> Attempt_PickA (immediate) - check for more work
    if lib.length(queue_contents(q1)) > 0 then
        let next_load = lib.first(queue_contents(q1))
        let attempt_event = new AttemptServiceEvent
        event_rule(attempt_event) := "attempt_pick_a"
        event_scheduled_time(attempt_event) := sim_clocktime
        event_priority(attempt_event) := 5  // PickZoneA priority
        event_parameters(attempt_event) := [next_load]
        lib.add(future_event_list, attempt_event)
    endif

    // Schedule: Finish_PickA -> Attempt_Q3 (immediate) - flow to Label
    let attempt_q3_event = new AttemptQueueEvent
    event_rule(attempt_q3_event) := "attempt_q3"
    event_scheduled_time(attempt_q3_event) := sim_clocktime
    event_priority(attempt_q3_event) := 7  // Label priority
    event_parameters(attempt_q3_event) := [load]
    lib.add(future_event_list, attempt_q3_event)
endrule

// -----------------------------------------------------------------------------
// Finish_PickB: Finish service at Pick Zone B
// State Transition: S2 := S2 + 1
// -----------------------------------------------------------------------------

rule finish_pick_b(load: Load) =
    servers_available(server_pick_b) := servers_available(server_pick_b) + 1
    servers_busy(server_pick_b) := servers_busy(server_pick_b) - 1

    lib.remove(in_service(server_pick_b), load)

    let time_in_queue = service_start_time(load) - arrival_time(load)
    total_time_in_queue(q2) := total_time_in_queue(q2) + time_in_queue

    // Check for more work
    if lib.length(queue_contents(q2)) > 0 then
        let next_load = lib.first(queue_contents(q2))
        let attempt_event = new AttemptServiceEvent
        event_rule(attempt_event) := "attempt_pick_b"
        event_scheduled_time(attempt_event) := sim_clocktime
        event_priority(attempt_event) := 6  // PickZoneB priority
        event_parameters(attempt_event) := [next_load]
        lib.add(future_event_list, attempt_event)
    endif

    // Flow to Label (same as Zone A)
    let attempt_q3_event = new AttemptQueueEvent
    event_rule(attempt_q3_event) := "attempt_q3"
    event_scheduled_time(attempt_q3_event) := sim_clocktime
    event_priority(attempt_q3_event) := 7  // Label priority
    event_parameters(attempt_q3_event) := [load]
    lib.add(future_event_list, attempt_q3_event)
endrule

// -----------------------------------------------------------------------------
// Finish_Label: Finish service at Label station
// State Transition: S3 := S3 + 1
// -----------------------------------------------------------------------------

rule finish_label(load: Load) =
    servers_available(server_label) := servers_available(server_label) + 1
    servers_busy(server_label) := servers_busy(server_label) - 1

    lib.remove(in_service(server_label), load)

    // Check for more work
    if lib.length(queue_contents(q3)) > 0 then
        let next_load = lib.first(queue_contents(q3))
        let attempt_event = new AttemptServiceEvent
        event_rule(attempt_event) := "attempt_label"
        event_scheduled_time(attempt_event) := sim_clocktime
        event_priority(attempt_event) := 7  // Label priority
        event_parameters(attempt_event) := [next_load]
        lib.add(future_event_list, attempt_event)
    endif

    // Flow to Scan
    let attempt_q4_event = new AttemptQueueEvent
    event_rule(attempt_q4_event) := "attempt_q4"
    event_scheduled_time(attempt_q4_event) := sim_clocktime
    event_priority(attempt_q4_event) := 8  // Scan priority
    event_parameters(attempt_q4_event) := [load]
    lib.add(future_event_list, attempt_q4_event)
endrule

// -----------------------------------------------------------------------------
// Finish_Scan: Finish service at Scan station
// State Transition: S4 := S4 + 1
// -----------------------------------------------------------------------------

rule finish_scan(load: Load) =
    servers_available(server_scan) := servers_available(server_scan) + 1
    servers_busy(server_scan) := servers_busy(server_scan) - 1

    lib.remove(in_service(server_scan), load)

    // Check for more work
    if lib.length(queue_contents(q4)) > 0 then
        let next_load = lib.first(queue_contents(q4))
        let attempt_event = new AttemptServiceEvent
        event_rule(attempt_event) := "attempt_scan"
        event_scheduled_time(attempt_event) := sim_clocktime
        event_priority(attempt_event) := 8  // Scan priority
        event_parameters(attempt_event) := [next_load]
        lib.add(future_event_list, attempt_event)
    endif

    // Flow to Pack
    let attempt_q5_event = new AttemptQueueEvent
    event_rule(attempt_q5_event) := "attempt_q5"
    event_scheduled_time(attempt_q5_event) := sim_clocktime
    event_priority(attempt_q5_event) := 9  // Pack priority
    event_parameters(attempt_q5_event) := [load]
    lib.add(future_event_list, attempt_q5_event)
endrule

// -----------------------------------------------------------------------------
// Finish_Pack: Finish service at Pack station
// State Transition: S5 := S5 + 1
// -----------------------------------------------------------------------------

rule finish_pack(load: Load) =
    servers_available(server_pack) := servers_available(server_pack) + 1
    servers_busy(server_pack) := servers_busy(server_pack) - 1

    lib.remove(in_service(server_pack), load)

    // Check for more work
    if lib.length(queue_contents(q5)) > 0 then
        let next_load = lib.first(queue_contents(q5))
        let attempt_event = new AttemptServiceEvent
        event_rule(attempt_event) := "attempt_pack"
        event_scheduled_time(attempt_event) := sim_clocktime
        event_priority(attempt_event) := 9  // Pack priority
        event_parameters(attempt_event) := [next_load]
        lib.add(future_event_list, attempt_event)
    endif

    // Flow to Release
    let attempt_q6_event = new AttemptQueueEvent
    event_rule(attempt_q6_event) := "attempt_q6"
    event_scheduled_time(attempt_q6_event) := sim_clocktime
    event_priority(attempt_q6_event) := 10  // Release priority
    event_parameters(attempt_q6_event) := [load]
    lib.add(future_event_list, attempt_q6_event)
endrule

// -----------------------------------------------------------------------------
// Finish_Release: Finish service at Release station (final stage)
// State Transition: S6 := S6 + 1
// -----------------------------------------------------------------------------

rule finish_release(load: Load) =
    servers_available(server_release) := servers_available(server_release) + 1
    servers_busy(server_release) := servers_busy(server_release) - 1

    lib.remove(in_service(server_release), load)

    // Record departure
    departure_time(load) := sim_clocktime
    lib.add(departures(server_release), load)
    total_departures(server_release) := total_departures(server_release) + 1

    // Accumulate time in system
    let time_in_system = sim_clocktime - arrival_time(load)
    total_time_in_system(server_release) := total_time_in_system(server_release) + time_in_system

    // Check for more work
    if lib.length(queue_contents(q6)) > 0 then
        let next_load = lib.first(queue_contents(q6))
        let attempt_event = new AttemptServiceEvent
        event_rule(attempt_event) := "attempt_release"
        event_scheduled_time(attempt_event) := sim_clocktime
        event_priority(attempt_event) := 10  // Release priority
        event_parameters(attempt_event) := [next_load]
        lib.add(future_event_list, attempt_event)
    endif

    // Load exits system - no further scheduling
endrule

// =============================================================================
// INITIAL STATE
// =============================================================================

init:
    // Create generator objects
    gen_za1 := new Generator
    gen_za2 := new Generator
    gen_zb1 := new Generator
    gen_zb2 := new Generator

    // Create queue objects
    q1 := new Queue
    q2 := new Queue
    q3 := new Queue
    q4 := new Queue
    q5 := new Queue
    q6 := new Queue

    // Create server objects
    server_pick_a := new Server
    server_pick_b := new Server
    server_label := new Server
    server_scan := new Server
    server_pack := new Server
    server_release := new Server

    // Queue capacities (adjusted for stable system)
    Q1_max := 30   // Pick Zone A queue capacity
    Q2_max := 20   // Pick Zone B queue capacity (was 10)
    Q3_max := 50   // Label queue capacity
    Q4_max := 20   // Scan queue capacity
    Q5_max := 30   // Pack queue capacity
    Q6_max := 20   // Release queue capacity

    // Service capacities (adjusted for stable system - no blocking)
    S1_capacity := 4   // Pick Zone A servers (was 2)
    S2_capacity := 2   // Pick Zone B servers (was 1)
    S3_capacity := 3   // Label servers (unchanged)
    S4_capacity := 1   // Scan servers (unchanged)
    S5_capacity := 3   // Pack servers (was 1)
    S6_capacity := 2   // Release servers (was 1)

    // Initialize available servers
    servers_available(server_pick_a) := 4
    servers_available(server_pick_b) := 2
    servers_available(server_label) := 3
    servers_available(server_scan) := 1
    servers_available(server_pack) := 3
    servers_available(server_release) := 2

    // Initialize busy servers
    servers_busy(server_pick_a) := 0
    servers_busy(server_pick_b) := 0
    servers_busy(server_label) := 0
    servers_busy(server_scan) := 0
    servers_busy(server_pack) := 0
    servers_busy(server_release) := 0

    // Timing parameters (example values - adjust as needed)
    iat_c1_mean := 325.5
    iat_c2_mean := 527.6
    iat_c3_mean := 226.1
    iat_c4_mean := 985.6
    ist_s1_mean := 78.4
    ist_s2_mean := 76.2
    ist_s3_mean := 288.8
    ist_s4_mean := 31.2
    ist_s5_mean := 66.8
    ist_s6_mean := 1.0

    // Time settings
    sim_clocktime := 0.0
    sim_end_time := 1000.0

    // Counters
    load_id_counter := 0

    // Initialize queue lengths
    queue_length(q1) := 0
    queue_length(q2) := 0
    queue_length(q3) := 0
    queue_length(q4) := 0
    queue_length(q5) := 0
    queue_length(q6) := 0

    // Initialize lists
    future_event_list := []
    queue_contents(q1) := []
    queue_contents(q2) := []
    queue_contents(q3) := []
    queue_contents(q4) := []
    queue_contents(q5) := []
    queue_contents(q6) := []
    in_service(server_pick_a) := []
    in_service(server_pick_b) := []
    in_service(server_label) := []
    in_service(server_scan) := []
    in_service(server_pack) := []
    in_service(server_release) := []
    departures(server_release) := []

    // Initialize statistics
    total_arrivals(gen_za1) := 0
    total_arrivals(gen_za2) := 0
    total_arrivals(gen_zb1) := 0
    total_arrivals(gen_zb2) := 0
    total_departures(server_release) := 0
    total_time_in_system(server_release) := 0.0
    total_time_in_queue(q1) := 0.0
    total_time_in_queue(q2) := 0.0
    total_time_in_queue(q3) := 0.0
    total_time_in_queue(q4) := 0.0
    total_time_in_queue(q5) := 0.0
    total_time_in_queue(q6) := 0.0
endinit

// =============================================================================
// MAIN RULE
// =============================================================================

main rule main =
    // Initialize on first step
    if sim_clocktime == 0.0 and lib.length(future_event_list) == 0 then
        initialisation_routine()
    endif

    // Run while events exist and time not exceeded
    if lib.length(future_event_list) > 0 and sim_clocktime < sim_end_time then
        run_routine()
    endif
endrule
