// =============================================================================
// Event Graph Warehouse Outbound Process - SimASM v1.0
// =============================================================================
// A warehouse outbound process modeled using Event Graph formalism
// Based on the algebraic specification with 37 event vertices and 49 edges
// Includes: Zone A/B picking, labeling, scanning, packing, and release
// =============================================================================

// =============================================================================
// IMPORT LIBRARIES
// =============================================================================

import Random as rnd
import Stdlib as lib

// =============================================================================
// DOMAIN DECLARATIONS
// =============================================================================

domain Object
domain Generator <: Object
domain Queue <: Object
domain Server <: Object
domain Load <: Object

// Event domain hierarchy
domain Event <: Object
domain InitializeEvent <: Event
domain CreateEvent <: Event
domain AttemptQueueEvent <: Event
domain QueueEvent <: Event
domain AttemptServiceEvent <: Event
domain ServiceStartEvent <: Event
domain ServiceFinishEvent <: Event

// =============================================================================
// CONSTANT DECLARATIONS (Static 0-ary Functions)
// =============================================================================

// Generators for each creation type
const gen_za1: Generator  // Zone A Type 1 generator
const gen_za2: Generator  // Zone A Type 2 generator
const gen_zb1: Generator  // Zone B Type 1 generator
const gen_zb2: Generator  // Zone B Type 2 generator

// Queues for each station
const q1: Queue  // Queue for Pick Zone A
const q2: Queue  // Queue for Pick Zone B
const q3: Queue  // Queue for Label
const q4: Queue  // Queue for Scan
const q5: Queue  // Queue for Pack
const q6: Queue  // Queue for Release

// Servers for each station
const server_pick_a: Server   // Pick Zone A servers
const server_pick_b: Server   // Pick Zone B servers
const server_label: Server    // Label servers
const server_scan: Server     // Scan servers
const server_pack: Server     // Pack servers
const server_release: Server  // Release servers

// Queue capacities
const Q1_max: Nat  // Queue capacity for Pick Zone A
const Q2_max: Nat  // Queue capacity for Pick Zone B
const Q3_max: Nat  // Queue capacity for Label
const Q4_max: Nat  // Queue capacity for Scan
const Q5_max: Nat  // Queue capacity for Pack
const Q6_max: Nat  // Queue capacity for Release

// Service capacities
const S1_capacity: Nat  // Server capacity for Pick Zone A
const S2_capacity: Nat  // Server capacity for Pick Zone B
const S3_capacity: Nat  // Server capacity for Label
const S4_capacity: Nat  // Server capacity for Scan
const S5_capacity: Nat  // Server capacity for Pack
const S6_capacity: Nat  // Server capacity for Release

// Timing parameters (means for exponential distributions)
const iat_c1_mean: Real  // Interarrival time mean for Zone A Type 1
const iat_c2_mean: Real  // Interarrival time mean for Zone A Type 2
const iat_c3_mean: Real  // Interarrival time mean for Zone B Type 1
const iat_c4_mean: Real  // Interarrival time mean for Zone B Type 2
const ist_s1_mean: Real  // Service time mean for Pick Zone A
const ist_s2_mean: Real  // Service time mean for Pick Zone B
const ist_s3_mean: Real  // Service time mean for Label
const ist_s4_mean: Real  // Service time mean for Scan
const ist_s5_mean: Real  // Service time mean for Pack
const ist_s6_mean: Real  // Service time mean for Release

const sim_end_time: Real

// =============================================================================
// DYNAMIC VARIABLE DECLARATIONS (Dynamic 0-ary Functions)
// =============================================================================

var future_event_list: List<Event>
var sim_clocktime: Real
var load_id_counter: Nat
var current_event: Event

// =============================================================================
// RANDOM STREAM VARIABLES
// =============================================================================

// Creation interarrival times
var interarrival_c1: rnd.exponential(iat_c1_mean) as "creation_za1"
var interarrival_c2: rnd.exponential(iat_c2_mean) as "creation_za2"
var interarrival_c3: rnd.exponential(iat_c3_mean) as "creation_zb1"
var interarrival_c4: rnd.exponential(iat_c4_mean) as "creation_zb2"

// Service times
var service_time_s1: rnd.exponential(ist_s1_mean) as "service_pick_a"
var service_time_s2: rnd.exponential(ist_s2_mean) as "service_pick_b"
var service_time_s3: rnd.exponential(ist_s3_mean) as "service_label"
var service_time_s4: rnd.exponential(ist_s4_mean) as "service_scan"
var service_time_s5: rnd.exponential(ist_s5_mean) as "service_pack"
var service_time_s6: rnd.exponential(ist_s6_mean) as "service_release"

// =============================================================================
// STATIC FUNCTION DECLARATIONS
// =============================================================================

static function id(obj: Object): Nat
static function load_type(l: Load): Nat  // 1=ZA1, 2=ZA2, 3=ZB1, 4=ZB2

// =============================================================================
// DYNAMIC FUNCTION DECLARATIONS
// =============================================================================

// Time counters per load
dynamic function arrival_time(l: Load): Real
dynamic function service_start_time(l: Load): Real
dynamic function departure_time(l: Load): Real

// Queue state (Q1-Q6 as counts)
dynamic function queue_length(q: Queue): Nat

// Server state (S1-S6 as available servers)
dynamic function servers_available(s: Server): Nat
dynamic function servers_busy(s: Server): Nat

// Entity lists
dynamic function queue_contents(q: Queue): List<Load>
dynamic function in_service(s: Server): List<Load>
dynamic function departures(s: Server): List<Load>

// Statistics
dynamic function total_arrivals(g: Generator): Nat
dynamic function total_departures(s: Server): Nat
dynamic function total_time_in_system(s: Server): Real
dynamic function total_time_in_queue(q: Queue): Real

// Event properties
dynamic function event_rule(e: Event): Rule
dynamic function event_scheduled_time(e: Event): Real
dynamic function event_parameters(e: Event): List<Any>
dynamic function event_priority(e: Event): Nat  // Lower = higher priority for tie-breaking

// =============================================================================
// DERIVED FUNCTIONS (Observable State)
// =============================================================================

derived function get_Q1(): Nat = queue_length(q1)
derived function get_Q2(): Nat = queue_length(q2)
derived function get_Q3(): Nat = queue_length(q3)
derived function get_Q4(): Nat = queue_length(q4)
derived function get_Q5(): Nat = queue_length(q5)
derived function get_Q6(): Nat = queue_length(q6)

derived function get_S1_available(): Nat = servers_available(server_pick_a)
derived function get_S2_available(): Nat = servers_available(server_pick_b)
derived function get_S3_available(): Nat = servers_available(server_label)
derived function get_S4_available(): Nat = servers_available(server_scan)
derived function get_S5_available(): Nat = servers_available(server_pack)
derived function get_S6_available(): Nat = servers_available(server_release)

derived function total_in_system(): Nat =
    get_Q1() + get_Q2() + get_Q3() + get_Q4() + get_Q5() + get_Q6() +
    servers_busy(server_pick_a) + servers_busy(server_pick_b) +
    servers_busy(server_label) + servers_busy(server_scan) +
    servers_busy(server_pack) + servers_busy(server_release)

// =============================================================================
// OBSERVABLE STATE PREDICATES (for verification)
// =============================================================================

// S1 busy predicates (Pick Zone A) - capacity 4
derived function s1_busy_eq_0(): Bool = servers_busy(server_pick_a) == 0
derived function s1_busy_eq_1(): Bool = servers_busy(server_pick_a) == 1
derived function s1_busy_eq_2(): Bool = servers_busy(server_pick_a) == 2
derived function s1_busy_eq_3(): Bool = servers_busy(server_pick_a) == 3
derived function s1_busy_eq_4(): Bool = servers_busy(server_pick_a) == 4

// S2 busy predicates (Pick Zone B) - capacity 2
derived function s2_busy_eq_0(): Bool = servers_busy(server_pick_b) == 0
derived function s2_busy_eq_1(): Bool = servers_busy(server_pick_b) == 1
derived function s2_busy_eq_2(): Bool = servers_busy(server_pick_b) == 2

// S3 busy predicates (Label) - capacity 3
derived function s3_busy_eq_0(): Bool = servers_busy(server_label) == 0
derived function s3_busy_eq_1(): Bool = servers_busy(server_label) == 1
derived function s3_busy_eq_2(): Bool = servers_busy(server_label) == 2
derived function s3_busy_eq_3(): Bool = servers_busy(server_label) == 3

// S4 busy predicates (Scan) - capacity 1
derived function s4_busy_eq_0(): Bool = servers_busy(server_scan) == 0
derived function s4_busy_eq_1(): Bool = servers_busy(server_scan) == 1

// S5 busy predicates (Pack) - capacity 3
derived function s5_busy_eq_0(): Bool = servers_busy(server_pack) == 0
derived function s5_busy_eq_1(): Bool = servers_busy(server_pack) == 1
derived function s5_busy_eq_2(): Bool = servers_busy(server_pack) == 2
derived function s5_busy_eq_3(): Bool = servers_busy(server_pack) == 3

// S6 busy predicates (Release) - capacity 2
derived function s6_busy_eq_0(): Bool = servers_busy(server_release) == 0
derived function s6_busy_eq_1(): Bool = servers_busy(server_release) == 1
derived function s6_busy_eq_2(): Bool = servers_busy(server_release) == 2

// =============================================================================
// RULES (Event Graph Routines)
// =============================================================================

// -----------------------------------------------------------------------------
// Initialization Routine
// -----------------------------------------------------------------------------

rule initialisation_routine() =
    // Schedule initial creation events for all four generators
    // Priority scheme: CreateZA1=1, CreateZA2=2, CreateZB1=3, CreateZB2=4
    //                  PickZoneA=5, PickZoneB=6, Label=7, Scan=8, Pack=9, Release=10

    // Initialize -> Create_ZA1
    let event_za1 = new CreateEvent
    event_rule(event_za1) := "create_za1"
    event_scheduled_time(event_za1) := sim_clocktime + interarrival_c1
    event_priority(event_za1) := 1
    event_parameters(event_za1) := []
    lib.add(future_event_list, event_za1)

    // Initialize -> Create_ZA2
    let event_za2 = new CreateEvent
    event_rule(event_za2) := "create_za2"
    event_scheduled_time(event_za2) := sim_clocktime + interarrival_c2
    event_priority(event_za2) := 2
    event_parameters(event_za2) := []
    lib.add(future_event_list, event_za2)

    // Initialize -> Create_ZB1
    let event_zb1 = new CreateEvent
    event_rule(event_zb1) := "create_zb1"
    event_scheduled_time(event_zb1) := sim_clocktime + interarrival_c3
    event_priority(event_zb1) := 3
    event_parameters(event_zb1) := []
    lib.add(future_event_list, event_zb1)

    // Initialize -> Create_ZB2
    let event_zb2 = new CreateEvent
    event_rule(event_zb2) := "create_zb2"
    event_scheduled_time(event_zb2) := sim_clocktime + interarrival_c4
    event_priority(event_zb2) := 4
    event_parameters(event_zb2) := []
    lib.add(future_event_list, event_zb2)
endrule

// -----------------------------------------------------------------------------
// Timing Routine
// -----------------------------------------------------------------------------

rule timing_routine() =
    // Sort by (scheduled_time, priority) - lower priority number = higher priority
    lib.sort(future_event_list, "event_scheduled_time", "event_priority")

    if lib.length(future_event_list) > 0 then
        let next_event = lib.pop(future_event_list)
        sim_clocktime := event_scheduled_time(next_event)
        current_event := next_event
    endif
endrule

// -----------------------------------------------------------------------------
// Event Routine
// -----------------------------------------------------------------------------

rule event_routine() =
    let r = event_rule(current_event)
    let params = event_parameters(current_event)
    lib.apply_rule(r, params)
endrule

// -----------------------------------------------------------------------------
// Run Routine
// -----------------------------------------------------------------------------

rule run_routine() =
    timing_routine()
    event_routine()
endrule

// =============================================================================
// CREATION EVENTS
// =============================================================================

// -----------------------------------------------------------------------------
// Create_ZA1: Zone A Type 1 creation
// State Transition: (no state change)
// -----------------------------------------------------------------------------

rule create_za1() =
    // Create new load (no state variable change per specification)
    load_id_counter := load_id_counter + 1
    let load = new Load
    id(load) := load_id_counter
    load_type(load) := 1
    arrival_time(load) := sim_clocktime
    total_arrivals(gen_za1) := total_arrivals(gen_za1) + 1

    // Schedule self-loop: Create_ZA1 -> Create_ZA1 (delay t^c1)
    let next_create = new CreateEvent
    event_rule(next_create) := "create_za1"
    event_scheduled_time(next_create) := sim_clocktime + interarrival_c1
    event_priority(next_create) := 1
    event_parameters(next_create) := []
    lib.add(future_event_list, next_create)

    // Schedule: Create_ZA1 -> Attempt_Q1_ZA1 (immediate, condition: true)
    let attempt_event = new AttemptQueueEvent
    event_rule(attempt_event) := "attempt_q1_za1"
    event_scheduled_time(attempt_event) := sim_clocktime
    event_priority(attempt_event) := 1
    event_parameters(attempt_event) := [load]
    lib.add(future_event_list, attempt_event)
endrule

// -----------------------------------------------------------------------------
// Create_ZA2: Zone A Type 2 creation
// State Transition: (no state change)
// -----------------------------------------------------------------------------

rule create_za2() =
    // Create new load
    load_id_counter := load_id_counter + 1
    let load = new Load
    id(load) := load_id_counter
    load_type(load) := 2
    arrival_time(load) := sim_clocktime
    total_arrivals(gen_za2) := total_arrivals(gen_za2) + 1

    // Self-loop
    let next_create = new CreateEvent
    event_rule(next_create) := "create_za2"
    event_scheduled_time(next_create) := sim_clocktime + interarrival_c2
    event_priority(next_create) := 2
    event_parameters(next_create) := []
    lib.add(future_event_list, next_create)

    // -> Attempt_Q1_ZA2
    let attempt_event = new AttemptQueueEvent
    event_rule(attempt_event) := "attempt_q1_za2"
    event_scheduled_time(attempt_event) := sim_clocktime
    event_priority(attempt_event) := 2
    event_parameters(attempt_event) := [load]
    lib.add(future_event_list, attempt_event)
endrule

// -----------------------------------------------------------------------------
// Create_ZB1: Zone B Type 1 creation
// State Transition: (no state change)
// -----------------------------------------------------------------------------

rule create_zb1() =
    // Create new load
    load_id_counter := load_id_counter + 1
    let load = new Load
    id(load) := load_id_counter
    load_type(load) := 3
    arrival_time(load) := sim_clocktime
    total_arrivals(gen_zb1) := total_arrivals(gen_zb1) + 1

    // Self-loop
    let next_create = new CreateEvent
    event_rule(next_create) := "create_zb1"
    event_scheduled_time(next_create) := sim_clocktime + interarrival_c3
    event_priority(next_create) := 3
    event_parameters(next_create) := []
    lib.add(future_event_list, next_create)

    // -> Attempt_Q2_ZB1
    let attempt_event = new AttemptQueueEvent
    event_rule(attempt_event) := "attempt_q2_zb1"
    event_scheduled_time(attempt_event) := sim_clocktime
    event_priority(attempt_event) := 3
    event_parameters(attempt_event) := [load]
    lib.add(future_event_list, attempt_event)
endrule

// -----------------------------------------------------------------------------
// Create_ZB2: Zone B Type 2 creation
// State Transition: (no state change)
// -----------------------------------------------------------------------------

rule create_zb2() =
    // Create new load
    load_id_counter := load_id_counter + 1
    let load = new Load
    id(load) := load_id_counter
    load_type(load) := 4
    arrival_time(load) := sim_clocktime
    total_arrivals(gen_zb2) := total_arrivals(gen_zb2) + 1

    // Self-loop
    let next_create = new CreateEvent
    event_rule(next_create) := "create_zb2"
    event_scheduled_time(next_create) := sim_clocktime + interarrival_c4
    event_priority(next_create) := 4
    event_parameters(next_create) := []
    lib.add(future_event_list, next_create)

    // -> Attempt_Q2_ZB2
    let attempt_event = new AttemptQueueEvent
    event_rule(attempt_event) := "attempt_q2_zb2"
    event_scheduled_time(attempt_event) := sim_clocktime
    event_priority(attempt_event) := 4
    event_parameters(attempt_event) := [load]
    lib.add(future_event_list, attempt_event)
endrule

// =============================================================================
// QUEUE ATTEMPT EVENTS
// =============================================================================

// -----------------------------------------------------------------------------
// Attempt_Q1_ZA1: Attempt to queue Zone A Type 1 for Pick Zone A
// State Transition: (no state change)
// Condition: Q1 < Q1_max
// -----------------------------------------------------------------------------

rule attempt_q1_za1(load: Load) =
    // No state change per specification
    // Check condition: Q1 < Q1_max
    if queue_length(q1) < Q1_max then
        // Schedule: Attempt_Q1_ZA1 -> Queue_Q1 (immediate)
        let queue_event = new QueueEvent
        event_rule(queue_event) := "queue_q1"
        event_scheduled_time(queue_event) := sim_clocktime
        event_priority(queue_event) := 5  // PickZoneA priority
        event_parameters(queue_event) := [load]
        lib.add(future_event_list, queue_event)
    endif
    // If queue full, load is blocked/lost (no edge fires)
endrule

// -----------------------------------------------------------------------------
// Attempt_Q1_ZA2: Attempt to queue Zone A Type 2 for Pick Zone A
// State Transition: (no state change)
// Condition: Q1 < Q1_max
// -----------------------------------------------------------------------------

rule attempt_q1_za2(load: Load) =
    // No state change per specification
    if queue_length(q1) < Q1_max then
        let queue_event = new QueueEvent
        event_rule(queue_event) := "queue_q1"
        event_scheduled_time(queue_event) := sim_clocktime
        event_priority(queue_event) := 5  // PickZoneA priority
        event_parameters(queue_event) := [load]
        lib.add(future_event_list, queue_event)
    endif
endrule

// -----------------------------------------------------------------------------
// Attempt_Q2_ZB1: Attempt to queue Zone B Type 1 for Pick Zone B
// State Transition: (no state change)
// Condition: Q2 < Q2_max
// -----------------------------------------------------------------------------

rule attempt_q2_zb1(load: Load) =
