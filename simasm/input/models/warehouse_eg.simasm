endrule

// =============================================================================
// SERVICE ATTEMPT EVENTS
// =============================================================================

// -----------------------------------------------------------------------------
// Attempt_PickA: Attempt to start service at Pick Zone A
// Condition: S1 > 0
// -----------------------------------------------------------------------------

rule attempt_pick_a(load: Load) =
    if servers_available(server_pick_a) > 0 and lib.length(queue_contents(q1)) > 0 then
        let load_to_start = lib.first(queue_contents(q1))

        let start_event = new ServiceStartEvent
        event_rule(start_event) := "pick_za"
        event_scheduled_time(start_event) := sim_clocktime
        event_priority(start_event) := 5  // PickZoneA priority
        event_parameters(start_event) := [load_to_start]
        lib.add(future_event_list, start_event)
    endif
endrule

// -----------------------------------------------------------------------------
// Attempt_PickB: Attempt to start service at Pick Zone B
// Condition: S2 > 0
// -----------------------------------------------------------------------------

rule attempt_pick_b(load: Load) =
    if servers_available(server_pick_b) > 0 and lib.length(queue_contents(q2)) > 0 then
        let load_to_start = lib.first(queue_contents(q2))

        let start_event = new ServiceStartEvent
        event_rule(start_event) := "pick_zb"
        event_scheduled_time(start_event) := sim_clocktime
        event_priority(start_event) := 6  // PickZoneB priority
        event_parameters(start_event) := [load_to_start]
        lib.add(future_event_list, start_event)
    endif
endrule

