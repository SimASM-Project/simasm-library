// Attempt_Pack: Attempt to start service at Pack station
// Condition: S5 > 0
// -----------------------------------------------------------------------------

rule attempt_pack(load: Load) =
    if servers_available(server_pack) > 0 and lib.length(queue_contents(q5)) > 0 then
        let load_to_start = lib.first(queue_contents(q5))

        let start_event = new ServiceStartEvent
