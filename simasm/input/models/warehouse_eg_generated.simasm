// -----------------------------------------------------------------------------
// Decision node - attempt to start Scan service

rule event_attempt_scan() =
    // Process scheduling edges E_s(G)
    // Start if server available and job waiting
    if S4 > 0 and Q4 > 0 then
        let scheduled_start_scan = new StartScanEvent
        event_rule(scheduled_start_scan) := "event_start_scan"
        event_scheduled_time(scheduled_start_scan) := sim_clocktime
        event_parameters(scheduled_start_scan) := []
        lib.add(future_event_list, scheduled_start_scan)
