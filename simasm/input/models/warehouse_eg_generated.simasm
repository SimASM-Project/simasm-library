rule event_start_pack() =
    // State transition: Q5 := Q5 - 1; S5 := S5 - 1
    Q5 := Q5 - 1
    S5 := S5 - 1

    // Process scheduling edges E_s(G)
    // Schedule service completion
    let scheduled_finish_pack = new FinishPackEvent
    event_rule(scheduled_finish_pack) := "event_finish_pack"
    event_scheduled_time(scheduled_finish_pack) := sim_clocktime + T_s5
    event_parameters(scheduled_finish_pack) := []
    lib.add(future_event_list, scheduled_finish_pack)

endrule

// -----------------------------------------------------------------------------
// StartRelease Event - f_StartRelease
// -----------------------------------------------------------------------------
// Start Release service - decrement Q6 and S6

rule event_start_release() =
    // State transition: Q6 := Q6 - 1; S6 := S6 - 1
    Q6 := Q6 - 1
    S6 := S6 - 1

    // Process scheduling edges E_s(G)
    // Schedule service completion
    let scheduled_finish_release = new FinishReleaseEvent
    event_rule(scheduled_finish_release) := "event_finish_release"
    event_scheduled_time(scheduled_finish_release) := sim_clocktime + T_s6
    event_parameters(scheduled_finish_release) := []
    lib.add(future_event_list, scheduled_finish_release)

endrule

// -----------------------------------------------------------------------------
// FinishPickA Event - f_FinishPickA
// -----------------------------------------------------------------------------
// Finish Pick Zone A - release server, job to Label queue

rule event_finish_pick_a() =
    // State transition: S1 := S1 + 1; Q3 := Q3 + 1
    S1 := S1 + 1
    Q3 := Q3 + 1

    // Process scheduling edges E_s(G)
    // Check for more work in queue
    if Q1 > 0 then
        let scheduled_attempt_pick_a = new AttemptPickAEvent
        event_rule(scheduled_attempt_pick_a) := "event_attempt_pick_a"
        event_scheduled_time(scheduled_attempt_pick_a) := sim_clocktime
        event_parameters(scheduled_attempt_pick_a) := []
        lib.add(future_event_list, scheduled_attempt_pick_a)
    endif

    // Flow job to Label
    if Q3 <= Q3_max then
        let scheduled_attempt_label = new AttemptLabelEvent
        event_rule(scheduled_attempt_label) := "event_attempt_label"
        event_scheduled_time(scheduled_attempt_label) := sim_clocktime
        event_parameters(scheduled_attempt_label) := []
        lib.add(future_event_list, scheduled_attempt_label)
    endif

endrule

// -----------------------------------------------------------------------------
// FinishPickB Event - f_FinishPickB
// -----------------------------------------------------------------------------
// Finish Pick Zone B - release server, job to Label queue

rule event_finish_pick_b() =
    // State transition: S2 := S2 + 1; Q3 := Q3 + 1
    S2 := S2 + 1
    Q3 := Q3 + 1

    // Process scheduling edges E_s(G)
    // Check for more work in queue
    if Q2 > 0 then
        let scheduled_attempt_pick_b = new AttemptPickBEvent
        event_rule(scheduled_attempt_pick_b) := "event_attempt_pick_b"
        event_scheduled_time(scheduled_attempt_pick_b) := sim_clocktime
        event_parameters(scheduled_attempt_pick_b) := []
        lib.add(future_event_list, scheduled_attempt_pick_b)
    endif

    // Flow job to Label
    if Q3 <= Q3_max then
        let scheduled_attempt_label = new AttemptLabelEvent
        event_rule(scheduled_attempt_label) := "event_attempt_label"
        event_scheduled_time(scheduled_attempt_label) := sim_clocktime
        event_parameters(scheduled_attempt_label) := []
        lib.add(future_event_list, scheduled_attempt_label)
    endif

endrule

// -----------------------------------------------------------------------------
// FinishLabel Event - f_FinishLabel
// -----------------------------------------------------------------------------
// Finish Label - release server, job to Scan queue

rule event_finish_label() =
    // State transition: S3 := S3 + 1; Q4 := Q4 + 1
    S3 := S3 + 1
    Q4 := Q4 + 1

    // Process scheduling edges E_s(G)
    // Check for more work in queue
    if Q3 > 0 then
        let scheduled_attempt_label = new AttemptLabelEvent
        event_rule(scheduled_attempt_label) := "event_attempt_label"
        event_scheduled_time(scheduled_attempt_label) := sim_clocktime
        event_parameters(scheduled_attempt_label) := []
        lib.add(future_event_list, scheduled_attempt_label)
    endif

    // Flow job to Scan
    if Q4 <= Q4_max then
        let scheduled_attempt_scan = new AttemptScanEvent
        event_rule(scheduled_attempt_scan) := "event_attempt_scan"
        event_scheduled_time(scheduled_attempt_scan) := sim_clocktime
        event_parameters(scheduled_attempt_scan) := []
        lib.add(future_event_list, scheduled_attempt_scan)
    endif

endrule

// -----------------------------------------------------------------------------
// FinishScan Event - f_FinishScan
// -----------------------------------------------------------------------------
// Finish Scan - release server, job to Pack queue

rule event_finish_scan() =
    // State transition: S4 := S4 + 1; Q5 := Q5 + 1
    S4 := S4 + 1
    Q5 := Q5 + 1

    // Process scheduling edges E_s(G)
    // Check for more work in queue
    if Q4 > 0 then
        let scheduled_attempt_scan = new AttemptScanEvent
        event_rule(scheduled_attempt_scan) := "event_attempt_scan"
        event_scheduled_time(scheduled_attempt_scan) := sim_clocktime
        event_parameters(scheduled_attempt_scan) := []
        lib.add(future_event_list, scheduled_attempt_scan)
    endif

    // Flow job to Pack
    if Q5 <= Q5_max then
        let scheduled_attempt_pack = new AttemptPackEvent
        event_rule(scheduled_attempt_pack) := "event_attempt_pack"
        event_scheduled_time(scheduled_attempt_pack) := sim_clocktime
        event_parameters(scheduled_attempt_pack) := []
        lib.add(future_event_list, scheduled_attempt_pack)
    endif

endrule

// -----------------------------------------------------------------------------
// FinishPack Event - f_FinishPack
// -----------------------------------------------------------------------------
// Finish Pack - release server, job to Release queue

rule event_finish_pack() =
    // State transition: S5 := S5 + 1; Q6 := Q6 + 1
    S5 := S5 + 1
    Q6 := Q6 + 1

    // Process scheduling edges E_s(G)
    // Check for more work in queue
    if Q5 > 0 then
        let scheduled_attempt_pack = new AttemptPackEvent
        event_rule(scheduled_attempt_pack) := "event_attempt_pack"
        event_scheduled_time(scheduled_attempt_pack) := sim_clocktime
        event_parameters(scheduled_attempt_pack) := []
        lib.add(future_event_list, scheduled_attempt_pack)
    endif

    // Flow job to Release
    if Q6 <= Q6_max then
        let scheduled_attempt_release = new AttemptReleaseEvent
        event_rule(scheduled_attempt_release) := "event_attempt_release"
        event_scheduled_time(scheduled_attempt_release) := sim_clocktime
        event_parameters(scheduled_attempt_release) := []
        lib.add(future_event_list, scheduled_attempt_release)
    endif

endrule

// -----------------------------------------------------------------------------
// FinishRelease Event - f_FinishRelease
// -----------------------------------------------------------------------------
// Finish Release - release server, job exits system

rule event_finish_release() =
    // State transition: S6 := S6 + 1; departures := departures + 1
    S6 := S6 + 1
    departures := departures + 1

    // Process scheduling edges E_s(G)
    // Check for more work in queue
    if Q6 > 0 then
        let scheduled_attempt_release = new AttemptReleaseEvent
        event_rule(scheduled_attempt_release) := "event_attempt_release"
        event_scheduled_time(scheduled_attempt_release) := sim_clocktime
        event_parameters(scheduled_attempt_release) := []
        lib.add(future_event_list, scheduled_attempt_release)
    endif

endrule

// =============================================================================
// NEXT-EVENT TIME-ADVANCE ALGORITHM
// =============================================================================

// -----------------------------------------------------------------------------
// Initialization Routine
// -----------------------------------------------------------------------------
// Set STATE := STATE_0, FEL := FEL_0

rule initialisation_routine() =
    // Schedule initial CreateZA1 event
    let init_event_0 = new CreateZA1Event
    event_rule(init_event_0) := "event_create_za1"
    event_scheduled_time(init_event_0) := sim_clocktime + T_c1
    event_parameters(init_event_0) := []
    lib.add(future_event_list, init_event_0)

    // Schedule initial CreateZA2 event
    let init_event_1 = new CreateZA2Event
    event_rule(init_event_1) := "event_create_za2"
    event_scheduled_time(init_event_1) := sim_clocktime + T_c2
    event_parameters(init_event_1) := []
    lib.add(future_event_list, init_event_1)

    // Schedule initial CreateZB1 event
    let init_event_2 = new CreateZB1Event
    event_rule(init_event_2) := "event_create_zb1"
    event_scheduled_time(init_event_2) := sim_clocktime + T_c3
    event_parameters(init_event_2) := []
    lib.add(future_event_list, init_event_2)

    // Schedule initial CreateZB2 event
    let init_event_3 = new CreateZB2Event
    event_rule(init_event_3) := "event_create_zb2"
    event_scheduled_time(init_event_3) := sim_clocktime + T_c4
    event_parameters(init_event_3) := []
    lib.add(future_event_list, init_event_3)

endrule

// -----------------------------------------------------------------------------
// Timing Routine
// -----------------------------------------------------------------------------
// Pop earliest event from FEL, advance clock to event time

rule timing_routine() =
    // Sort FEL by (scheduled_time, -priority)
    lib.sort(future_event_list, "event_scheduled_time")

    if lib.length(future_event_list) > 0 then
        // Remove next event from FEL
        let next_event = lib.pop(future_event_list)

        // Advance simulation clock
        sim_clocktime := event_scheduled_time(next_event)

        // Store for event routine dispatch
        current_event := next_event
    endif
endrule

// -----------------------------------------------------------------------------
// Event Routine
// -----------------------------------------------------------------------------
// Dispatch to event-specific rule using lib.apply_rule

rule event_routine() =
    let r = event_rule(current_event)
    let params = event_parameters(current_event)
    lib.apply_rule(r, params)
endrule

// =============================================================================
// INITIAL STATE - STATE_0
// =============================================================================

init:
    // Parameters
    Q1_max := 30
    Q2_max := 20
    Q3_max := 50
    Q4_max := 20
    Q5_max := 30
    Q6_max := 20
    S1_capacity := 4
    S2_capacity := 2
    S3_capacity := 3
    S4_capacity := 1
    S5_capacity := 3
    S6_capacity := 2
    iat_c1_mean := 2.0
    iat_c2_mean := 3.0
    iat_c3_mean := 4.0
    iat_c4_mean := 5.0
    ist_s1_mean := 3.0
    ist_s2_mean := 4.0
    ist_s3_mean := 1.5
    ist_s4_mean := 0.5
    ist_s5_mean := 2.0
    ist_s6_mean := 1.0
    sim_end_time := 1000.0

    // Simulation state
    sim_clocktime := 0.0
    future_event_list := []

    // Initial state variables STATE_0
    Q1 := 0
    Q2 := 0
    Q3 := 0
    Q4 := 0
    Q5 := 0
    Q6 := 0
    S1 := 4
    S2 := 2
    S3 := 3
    S4 := 1
    S5 := 3
    S6 := 2
    departures := 0
endinit

// =============================================================================
// MAIN RULE
// =============================================================================

main rule main =
    // Initialize on first step
    if sim_clocktime == 0.0 and lib.length(future_event_list) == 0 then
        initialisation_routine()
    endif

    // Run while FEL not empty and time not exceeded
    if lib.length(future_event_list) > 0 and sim_clocktime < sim_end_time then
        timing_routine()
        event_routine()
    endif
endrule

