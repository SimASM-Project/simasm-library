rule event_start_label() =
    // State transition: Q3 := Q3 - 1; S3 := S3 - 1
    Q3 := Q3 - 1
    S3 := S3 - 1

    // Process scheduling edges E_s(G)
    // Schedule service completion
    let scheduled_finish_label = new FinishLabelEvent
    event_rule(scheduled_finish_label) := "event_finish_label"
    event_scheduled_time(scheduled_finish_label) := sim_clocktime + T_s3
    event_parameters(scheduled_finish_label) := []
    lib.add(future_event_list, scheduled_finish_label)

endrule

// -----------------------------------------------------------------------------
// StartScan Event - f_StartScan
// -----------------------------------------------------------------------------
// Start Scan service - decrement Q4 and S4

rule event_start_scan() =
    // State transition: Q4 := Q4 - 1; S4 := S4 - 1
    Q4 := Q4 - 1
    S4 := S4 - 1

    // Process scheduling edges E_s(G)
    // Schedule service completion
    let scheduled_finish_scan = new FinishScanEvent
    event_rule(scheduled_finish_scan) := "event_finish_scan"
    event_scheduled_time(scheduled_finish_scan) := sim_clocktime + T_s4
    event_parameters(scheduled_finish_scan) := []
    lib.add(future_event_list, scheduled_finish_scan)

endrule

// -----------------------------------------------------------------------------
// StartPack Event - f_StartPack
// -----------------------------------------------------------------------------
