rule event_attempt_pack() =
    // Process scheduling edges E_s(G)
    // Start if server available and job waiting
    if S5 > 0 and Q5 > 0 then
        let scheduled_start_pack = new StartPackEvent
        event_rule(scheduled_start_pack) := "event_start_pack"
        event_scheduled_time(scheduled_start_pack) := sim_clocktime
        event_parameters(scheduled_start_pack) := []
        lib.add(future_event_list, scheduled_start_pack)
    endif

endrule

// -----------------------------------------------------------------------------
// AttemptRelease Event - f_AttemptRelease
// -----------------------------------------------------------------------------
// Decision node - attempt to start Release service

rule event_attempt_release() =
    // Process scheduling edges E_s(G)
    // Start if server available and job waiting
    if S6 > 0 and Q6 > 0 then
        let scheduled_start_release = new StartReleaseEvent
        event_rule(scheduled_start_release) := "event_start_release"
        event_scheduled_time(scheduled_start_release) := sim_clocktime
        event_parameters(scheduled_start_release) := []
        lib.add(future_event_list, scheduled_start_release)
    endif

endrule

// -----------------------------------------------------------------------------
// StartPickA Event - f_StartPickA
// -----------------------------------------------------------------------------
// Start Pick Zone A service - decrement Q1 and S1

rule event_start_pick_a() =
    // State transition: Q1 := Q1 - 1; S1 := S1 - 1
    Q1 := Q1 - 1
    S1 := S1 - 1

    // Process scheduling edges E_s(G)
    // Schedule service completion
    let scheduled_finish_pick_a = new FinishPickAEvent
    event_rule(scheduled_finish_pick_a) := "event_finish_pick_a"
    event_scheduled_time(scheduled_finish_pick_a) := sim_clocktime + T_s1
    event_parameters(scheduled_finish_pick_a) := []
    lib.add(future_event_list, scheduled_finish_pick_a)

endrule

// -----------------------------------------------------------------------------
// StartPickB Event - f_StartPickB
// -----------------------------------------------------------------------------
// Start Pick Zone B service - decrement Q2 and S2

rule event_start_pick_b() =
    // State transition: Q2 := Q2 - 1; S2 := S2 - 1
    Q2 := Q2 - 1
    S2 := S2 - 1

    // Process scheduling edges E_s(G)
    // Schedule service completion
    let scheduled_finish_pick_b = new FinishPickBEvent
    event_rule(scheduled_finish_pick_b) := "event_finish_pick_b"
    event_scheduled_time(scheduled_finish_pick_b) := sim_clocktime + T_s2
    event_parameters(scheduled_finish_pick_b) := []
    lib.add(future_event_list, scheduled_finish_pick_b)

endrule

// -----------------------------------------------------------------------------
// StartLabel Event - f_StartLabel
// -----------------------------------------------------------------------------
