// AttemptLabel Event - f_AttemptLabel
// -----------------------------------------------------------------------------
// Decision node - attempt to start Label service

rule event_attempt_label() =
    // Process scheduling edges E_s(G)
    // Start if server available and job waiting
    if S3 > 0 and Q3 > 0 then
        let scheduled_start_label = new StartLabelEvent
        event_rule(scheduled_start_label) := "event_start_label"
        event_scheduled_time(scheduled_start_label) := sim_clocktime
        event_parameters(scheduled_start_label) := []
        lib.add(future_event_list, scheduled_start_label)
    endif

endrule

