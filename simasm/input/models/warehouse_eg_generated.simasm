// =============================================================================
// Event Graph Model: warehouse_eg
// =============================================================================
// Warehouse Outbound Process using Event Graph formalism (Schruben 1983)
// Algebraic specification: S = (F, C, T, G)
// Based on warehouse_eg.simasm - simplified v2 format
// Generated: 2026-01-05 19:06:44
// Formalism: Event Graph (Schruben 1983)
// Algorithm: Next-Event Time-Advance (Law 2013)

// =============================================================================
// IMPORT LIBRARIES
// =============================================================================

import Random as rnd
import Stdlib as lib

// =============================================================================
// DOMAIN DECLARATIONS
// =============================================================================

// Base object domain
domain Object

// Event domain hierarchy - G = (V(G), E_s(G), E_c(G))
domain Event <: Object
domain CreateZA1Event <: Event
domain CreateZA2Event <: Event
domain CreateZB1Event <: Event
domain CreateZB2Event <: Event
domain AttemptPickAEvent <: Event
domain AttemptPickBEvent <: Event
domain AttemptLabelEvent <: Event
domain AttemptScanEvent <: Event
domain AttemptPackEvent <: Event
domain AttemptReleaseEvent <: Event
domain StartPickAEvent <: Event
domain StartPickBEvent <: Event
domain StartLabelEvent <: Event
domain StartScanEvent <: Event
domain StartPackEvent <: Event
domain StartReleaseEvent <: Event
domain FinishPickAEvent <: Event
domain FinishPickBEvent <: Event
domain FinishLabelEvent <: Event
domain FinishScanEvent <: Event
domain FinishPackEvent <: Event
domain FinishReleaseEvent <: Event

// =============================================================================
// CONSTANT DECLARATIONS
// =============================================================================

const Q1_max: Nat  // Pick Zone A queue capacity
const Q2_max: Nat  // Pick Zone B queue capacity
const Q3_max: Nat  // Labelling queue capacity
const Q4_max: Nat  // Scanning queue capacity
const Q5_max: Nat  // Packing queue capacity
const Q6_max: Nat  // Release queue capacity
const S1_capacity: Nat  // Pick Zone A servers
const S2_capacity: Nat  // Pick Zone B servers
const S3_capacity: Nat  // Labelling servers
const S4_capacity: Nat  // Scanning servers
const S5_capacity: Nat  // Packing servers
const S6_capacity: Nat  // Release servers
const iat_c1_mean: Real  // Interarrival time mean for Zone A Type 1
const iat_c2_mean: Real  // Interarrival time mean for Zone A Type 2
const iat_c3_mean: Real  // Interarrival time mean for Zone B Type 1
const iat_c4_mean: Real  // Interarrival time mean for Zone B Type 2
const ist_s1_mean: Real  // Service time mean for Pick Zone A
const ist_s2_mean: Real  // Service time mean for Pick Zone B
const ist_s3_mean: Real  // Service time mean for Label
const ist_s4_mean: Real  // Service time mean for Scan
const ist_s5_mean: Real  // Service time mean for Pack
const ist_s6_mean: Real  // Service time mean for Release
const sim_end_time: Real  // Simulation end time

// =============================================================================
// DYNAMIC VARIABLE DECLARATIONS - STATES space
// =============================================================================

// Simulation clock and event list
var sim_clocktime: Real
var future_event_list: List<Event>
var current_event: Event

// State variables (STATES)
var Q1: Nat  // Pick Zone A queue length
var Q2: Nat  // Pick Zone B queue length
var Q3: Nat  // Labelling queue length
var Q4: Nat  // Scanning queue length
var Q5: Nat  // Packing queue length
var Q6: Nat  // Release queue length
var S1: Nat  // Pick Zone A available servers
var S2: Nat  // Pick Zone B available servers
var S3: Nat  // Labelling available servers
var S4: Nat  // Scanning available servers
var S5: Nat  // Packing available servers
var S6: Nat  // Release available servers
var departures: Nat  // Total completed jobs

// =============================================================================
// RANDOM STREAM VARIABLES - Edge delay functions T
// =============================================================================

var T_c1: rnd.exponential(iat_c1_mean) as "creation_za1"
var T_c2: rnd.exponential(iat_c2_mean) as "creation_za2"
var T_c3: rnd.exponential(iat_c3_mean) as "creation_zb1"
var T_c4: rnd.exponential(iat_c4_mean) as "creation_zb2"
var T_s1: rnd.exponential(ist_s1_mean) as "service_pick_a"
var T_s2: rnd.exponential(ist_s2_mean) as "service_pick_b"
var T_s3: rnd.exponential(ist_s3_mean) as "service_label"
var T_s4: rnd.exponential(ist_s4_mean) as "service_scan"
var T_s5: rnd.exponential(ist_s5_mean) as "service_pack"
var T_s6: rnd.exponential(ist_s6_mean) as "service_release"

// =============================================================================
// DYNAMIC FUNCTION DECLARATIONS
// =============================================================================

// Event properties
dynamic function event_rule(e: Event): Rule
dynamic function event_scheduled_time(e: Event): Real
dynamic function event_parameters(e: Event): List<Any>

// =============================================================================
// DERIVED FUNCTIONS - Observables
// =============================================================================

derived function get_Q1(): Nat =  // Pick Zone A queue length
    Q1

derived function get_Q2(): Nat =  // Pick Zone B queue length
    Q2

derived function get_Q3(): Nat =  // Labelling queue length
    Q3

derived function get_Q4(): Nat =  // Scanning queue length
    Q4

derived function get_Q5(): Nat =  // Packing queue length
    Q5

derived function get_Q6(): Nat =  // Release queue length
    Q6

derived function get_S1_busy(): Nat =  // Pick Zone A busy servers
    S1_capacity - S1

derived function get_S2_busy(): Nat =  // Pick Zone B busy servers
    S2_capacity - S2

derived function get_S3_busy(): Nat =  // Labelling busy servers
    S3_capacity - S3

derived function get_S4_busy(): Nat =  // Scanning busy servers
    S4_capacity - S4

derived function get_S5_busy(): Nat =  // Packing busy servers
    S5_capacity - S5

derived function get_S6_busy(): Nat =  // Release busy servers
    S6_capacity - S6

derived function total_in_system(): Nat =  // Total jobs in system
    Q1 + Q2 + Q3 + Q4 + Q5 + Q6 + (S1_capacity - S1) + (S2_capacity - S2) + (S3_capacity - S3) + (S4_capacity - S4) + (S5_capacity - S5) + (S6_capacity - S6)

// =============================================================================
// EVENT RULES - State transition functions F
// =============================================================================

// -----------------------------------------------------------------------------
// CreateZA1 Event - f_CreateZA1
// -----------------------------------------------------------------------------
// Create Zone A Type 1 job - increment Q1

rule event_create_za1() =
    // State transition: Q1 := Q1 + 1
    Q1 := Q1 + 1

    // Process scheduling edges E_s(G)
    // Self-loop: schedule next ZA1 creation
    let scheduled_create_za1 = new CreateZA1Event
    event_rule(scheduled_create_za1) := "event_create_za1"
    event_scheduled_time(scheduled_create_za1) := sim_clocktime + T_c1
    event_parameters(scheduled_create_za1) := []
    lib.add(future_event_list, scheduled_create_za1)

    // After creation, attempt to start service
    if Q1 <= Q1_max then
        let scheduled_attempt_pick_a = new AttemptPickAEvent
        event_rule(scheduled_attempt_pick_a) := "event_attempt_pick_a"
        event_scheduled_time(scheduled_attempt_pick_a) := sim_clocktime
        event_parameters(scheduled_attempt_pick_a) := []
        lib.add(future_event_list, scheduled_attempt_pick_a)
    endif

endrule

// -----------------------------------------------------------------------------
// CreateZA2 Event - f_CreateZA2
// -----------------------------------------------------------------------------
// Create Zone A Type 2 job - increment Q1

rule event_create_za2() =
    // State transition: Q1 := Q1 + 1
    Q1 := Q1 + 1

    // Process scheduling edges E_s(G)
    // Self-loop: schedule next ZA2 creation
    let scheduled_create_za2 = new CreateZA2Event
    event_rule(scheduled_create_za2) := "event_create_za2"
    event_scheduled_time(scheduled_create_za2) := sim_clocktime + T_c2
    event_parameters(scheduled_create_za2) := []
    lib.add(future_event_list, scheduled_create_za2)

    // After creation, attempt to start service
    if Q1 <= Q1_max then
        let scheduled_attempt_pick_a = new AttemptPickAEvent
        event_rule(scheduled_attempt_pick_a) := "event_attempt_pick_a"
        event_scheduled_time(scheduled_attempt_pick_a) := sim_clocktime
        event_parameters(scheduled_attempt_pick_a) := []
        lib.add(future_event_list, scheduled_attempt_pick_a)
    endif

endrule

// -----------------------------------------------------------------------------
// CreateZB1 Event - f_CreateZB1
// -----------------------------------------------------------------------------
// Create Zone B Type 1 job - increment Q2

rule event_create_zb1() =
    // State transition: Q2 := Q2 + 1
    Q2 := Q2 + 1

    // Process scheduling edges E_s(G)
    // Self-loop: schedule next ZB1 creation
    let scheduled_create_zb1 = new CreateZB1Event
    event_rule(scheduled_create_zb1) := "event_create_zb1"
    event_scheduled_time(scheduled_create_zb1) := sim_clocktime + T_c3
    event_parameters(scheduled_create_zb1) := []
    lib.add(future_event_list, scheduled_create_zb1)

    // After creation, attempt to start service
    if Q2 <= Q2_max then
        let scheduled_attempt_pick_b = new AttemptPickBEvent
        event_rule(scheduled_attempt_pick_b) := "event_attempt_pick_b"
        event_scheduled_time(scheduled_attempt_pick_b) := sim_clocktime
        event_parameters(scheduled_attempt_pick_b) := []
        lib.add(future_event_list, scheduled_attempt_pick_b)
    endif

endrule

// -----------------------------------------------------------------------------
// CreateZB2 Event - f_CreateZB2
// -----------------------------------------------------------------------------
// Create Zone B Type 2 job - increment Q2

rule event_create_zb2() =
    // State transition: Q2 := Q2 + 1
    Q2 := Q2 + 1

    // Process scheduling edges E_s(G)
    // Self-loop: schedule next ZB2 creation
    let scheduled_create_zb2 = new CreateZB2Event
    event_rule(scheduled_create_zb2) := "event_create_zb2"
    event_scheduled_time(scheduled_create_zb2) := sim_clocktime + T_c4
    event_parameters(scheduled_create_zb2) := []
    lib.add(future_event_list, scheduled_create_zb2)

    // After creation, attempt to start service
    if Q2 <= Q2_max then
        let scheduled_attempt_pick_b = new AttemptPickBEvent
        event_rule(scheduled_attempt_pick_b) := "event_attempt_pick_b"
        event_scheduled_time(scheduled_attempt_pick_b) := sim_clocktime
        event_parameters(scheduled_attempt_pick_b) := []
        lib.add(future_event_list, scheduled_attempt_pick_b)
    endif

endrule

// -----------------------------------------------------------------------------
// AttemptPickA Event - f_AttemptPickA
// -----------------------------------------------------------------------------
// Decision node - attempt to start Pick Zone A service

rule event_attempt_pick_a() =
    // Process scheduling edges E_s(G)
    // Start if server available and job waiting
    if S1 > 0 and Q1 > 0 then
        let scheduled_start_pick_a = new StartPickAEvent
        event_rule(scheduled_start_pick_a) := "event_start_pick_a"
        event_scheduled_time(scheduled_start_pick_a) := sim_clocktime
        event_parameters(scheduled_start_pick_a) := []
        lib.add(future_event_list, scheduled_start_pick_a)
    endif

endrule

// -----------------------------------------------------------------------------
// AttemptPickB Event - f_AttemptPickB
// -----------------------------------------------------------------------------
// Decision node - attempt to start Pick Zone B service

rule event_attempt_pick_b() =
    // Process scheduling edges E_s(G)
    // Start if server available and job waiting
    if S2 > 0 and Q2 > 0 then
        let scheduled_start_pick_b = new StartPickBEvent
        event_rule(scheduled_start_pick_b) := "event_start_pick_b"
        event_scheduled_time(scheduled_start_pick_b) := sim_clocktime
        event_parameters(scheduled_start_pick_b) := []
        lib.add(future_event_list, scheduled_start_pick_b)
    endif

endrule

