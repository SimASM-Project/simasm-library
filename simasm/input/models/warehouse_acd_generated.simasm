    // Consume server_token from S5
    marking(S5) := marking(S5) - 1
    let server_token = lib.pop(tokens(S5))

    // Consume job_token from Q5
    marking(Q5) := marking(Q5) - 1
    let job_token = lib.pop(tokens(Q5))
    service_start_time(job_token) := sim_clocktime


    // Schedule BTO-event for activity completion
    let bto_event = new BTOEvent
    bto_activity(bto_event) := Pack
    bto_scheduled_time(bto_event) := sim_clocktime + duration_pack
    bto_tokens(bto_event) := [server_token, job_token]
    lib.add(future_event_list, bto_event)
endrule

rule at_begin_action_release() =
    // Consume server_token from S6
    marking(S6) := marking(S6) - 1
    let server_token = lib.pop(tokens(S6))

    // Consume job_token from Q6
    marking(Q6) := marking(Q6) - 1
    let job_token = lib.pop(tokens(Q6))
    service_start_time(job_token) := sim_clocktime


    // Schedule BTO-event for activity completion
    let bto_event = new BTOEvent
    bto_activity(bto_event) := Release
    bto_scheduled_time(bto_event) := sim_clocktime + duration_release
    bto_tokens(bto_event) := [server_token, job_token]
    lib.add(future_event_list, bto_event)
endrule

// -----------------------------------------------------------------------------
// At-end Actions (Activity completion)
// -----------------------------------------------------------------------------

rule at_end_action_createza1(bound_tokens: List<Token>) =
    // Arc 1: C1++ <- creator_token
    let creator_token = lib.get(bound_tokens, 0)
    lib.add(tokens(C1), creator_token)
    marking(C1) := marking(C1) + 1

    // Arc 2: Q1++ <- new Job
    if marking(Q1) < Q1_max then
        job_id_counter := job_id_counter + 1
        let new_job = new Job
        id(new_job) := job_id_counter
        arrival_time(new_job) := sim_clocktime
        lib.add(tokens(Q1), new_job)
        marking(Q1) := marking(Q1) + 1
    endif

endrule

rule at_end_action_createza2(bound_tokens: List<Token>) =
    // Arc 1: C2++ <- creator_token
    let creator_token = lib.get(bound_tokens, 0)
    lib.add(tokens(C2), creator_token)
    marking(C2) := marking(C2) + 1

    // Arc 2: Q1++ <- new Job
    if marking(Q1) < Q1_max then
        job_id_counter := job_id_counter + 1
        let new_job = new Job
        id(new_job) := job_id_counter
        arrival_time(new_job) := sim_clocktime
        lib.add(tokens(Q1), new_job)
        marking(Q1) := marking(Q1) + 1
    endif

endrule

rule at_end_action_createzb1(bound_tokens: List<Token>) =
    // Arc 1: C3++ <- creator_token
    let creator_token = lib.get(bound_tokens, 0)
    lib.add(tokens(C3), creator_token)
    marking(C3) := marking(C3) + 1

    // Arc 2: Q2++ <- new Job
    if marking(Q2) < Q2_max then
        job_id_counter := job_id_counter + 1
        let new_job = new Job
        id(new_job) := job_id_counter
        arrival_time(new_job) := sim_clocktime
        lib.add(tokens(Q2), new_job)
        marking(Q2) := marking(Q2) + 1
    endif

endrule

rule at_end_action_createzb2(bound_tokens: List<Token>) =
    // Arc 1: C4++ <- creator_token
    let creator_token = lib.get(bound_tokens, 0)
    lib.add(tokens(C4), creator_token)
    marking(C4) := marking(C4) + 1

    // Arc 2: Q2++ <- new Job
    if marking(Q2) < Q2_max then
        job_id_counter := job_id_counter + 1
        let new_job = new Job
        id(new_job) := job_id_counter
        arrival_time(new_job) := sim_clocktime
        lib.add(tokens(Q2), new_job)
        marking(Q2) := marking(Q2) + 1
    endif

endrule

rule at_end_action_pickzonea(bound_tokens: List<Token>) =
    // Arc 1: S1++ <- server_token
    let server_token = lib.get(bound_tokens, 0)
    lib.add(tokens(S1), server_token)
    marking(S1) := marking(S1) + 1

    // Arc 2: Q3++ <- job_token
    if marking(Q3) < Q3_max then
        let job_token = lib.get(bound_tokens, 1)
        lib.add(tokens(Q3), job_token)
        marking(Q3) := marking(Q3) + 1
    endif

endrule

rule at_end_action_pickzoneb(bound_tokens: List<Token>) =
    // Arc 1: S2++ <- server_token
    let server_token = lib.get(bound_tokens, 0)
    lib.add(tokens(S2), server_token)
    marking(S2) := marking(S2) + 1

    // Arc 2: Q3++ <- job_token
    if marking(Q3) < Q3_max then
        let job_token = lib.get(bound_tokens, 1)
        lib.add(tokens(Q3), job_token)
        marking(Q3) := marking(Q3) + 1
    endif

endrule

rule at_end_action_label(bound_tokens: List<Token>) =
    // Arc 1: S3++ <- server_token
    let server_token = lib.get(bound_tokens, 0)
    lib.add(tokens(S3), server_token)
    marking(S3) := marking(S3) + 1

    // Arc 2: Q4++ <- job_token
    if marking(Q4) < Q4_max then
        let job_token = lib.get(bound_tokens, 1)
        lib.add(tokens(Q4), job_token)
        marking(Q4) := marking(Q4) + 1
    endif

endrule

rule at_end_action_scan(bound_tokens: List<Token>) =
    // Arc 1: S4++ <- server_token
    let server_token = lib.get(bound_tokens, 0)
    lib.add(tokens(S4), server_token)
    marking(S4) := marking(S4) + 1

    // Arc 2: Q5++ <- job_token
    if marking(Q5) < Q5_max then
        let job_token = lib.get(bound_tokens, 1)
        lib.add(tokens(Q5), job_token)
        marking(Q5) := marking(Q5) + 1
    endif

endrule

rule at_end_action_pack(bound_tokens: List<Token>) =
    // Arc 1: S5++ <- server_token
    let server_token = lib.get(bound_tokens, 0)
    lib.add(tokens(S5), server_token)
    marking(S5) := marking(S5) + 1

    // Arc 2: Q6++ <- job_token
    if marking(Q6) < Q6_max then
        let job_token = lib.get(bound_tokens, 1)
        lib.add(tokens(Q6), job_token)
        marking(Q6) := marking(Q6) + 1
    endif

endrule

rule at_end_action_release(bound_tokens: List<Token>) =
    // Arc 1: S6++ <- server_token
    let server_token = lib.get(bound_tokens, 0)
    lib.add(tokens(S6), server_token)
    marking(S6) := marking(S6) + 1

    // Arc 2: Jobs++ <- job_token
    let job_token = lib.get(bound_tokens, 1)
    lib.add(tokens(Jobs), job_token)
    marking(Jobs) := marking(Jobs) + 1
    let time_in_system = sim_clocktime - arrival_time(job_token)
    let time_in_queue = service_start_time(job_token) - arrival_time(job_token)
    total_sojourn_time := total_sojourn_time + time_in_system
    total_time_in_queue := total_time_in_queue + time_in_queue
    departure_count := departure_count + 1

endrule

// -----------------------------------------------------------------------------
// Phase 1: B-phase (Scanning Phase) - One activity per step
// -----------------------------------------------------------------------------

rule scanning_phase_single() =
    activities_started := false

    // Try CreateZA1 first
    if not activities_started and at_begin_condition_createza1() then
        at_begin_action_createza1()
        activities_started := true
    endif

    // Try CreateZA2 only if previous didn't start
    if not activities_started and at_begin_condition_createza2() then
        at_begin_action_createza2()
        activities_started := true
    endif

    // Try CreateZB1 only if previous didn't start
    if not activities_started and at_begin_condition_createzb1() then
        at_begin_action_createzb1()
        activities_started := true
    endif

    // Try CreateZB2 only if previous didn't start
    if not activities_started and at_begin_condition_createzb2() then
        at_begin_action_createzb2()
        activities_started := true
    endif

    // Try PickZoneA only if previous didn't start
    if not activities_started and at_begin_condition_pickzonea() then
        at_begin_action_pickzonea()
        activities_started := true
    endif

    // Try PickZoneB only if previous didn't start
    if not activities_started and at_begin_condition_pickzoneb() then
        at_begin_action_pickzoneb()
        activities_started := true
    endif

    // Try Label only if previous didn't start
    if not activities_started and at_begin_condition_label() then
        at_begin_action_label()
        activities_started := true
    endif

    // Try Scan only if previous didn't start
    if not activities_started and at_begin_condition_scan() then
        at_begin_action_scan()
        activities_started := true
    endif

    // Try Pack only if previous didn't start
    if not activities_started and at_begin_condition_pack() then
        at_begin_action_pack()
        activities_started := true
    endif

    // Try Release only if previous didn't start
    if not activities_started and at_begin_condition_release() then
        at_begin_action_release()
        activities_started := true
    endif

endrule

// -----------------------------------------------------------------------------
// Phase 2: A-phase (Timing Phase) - advance clock
// -----------------------------------------------------------------------------

rule timing_phase() =
    // Sort FEL by scheduled time (uses dynamic function lookup)
    lib.sort(future_event_list, "bto_scheduled_time")

    // Get next event
    let next_event = lib.pop(future_event_list)

    // Advance clock
    sim_clocktime := bto_scheduled_time(next_event)

    // Execute the event
    executing_phase(next_event)
endrule

// -----------------------------------------------------------------------------
// Phase 3: C-phase (Executing Phase)
// -----------------------------------------------------------------------------

rule executing_phase(bto_event: BTOEvent) =
    let activity = bto_activity(bto_event)
    let bound_tokens = bto_tokens(bto_event)

    if activity == CreateZA1 then
        at_end_action_createza1(bound_tokens)
    endif

    if activity == CreateZA2 then
        at_end_action_createza2(bound_tokens)
    endif

    if activity == CreateZB1 then
        at_end_action_createzb1(bound_tokens)
    endif

    if activity == CreateZB2 then
        at_end_action_createzb2(bound_tokens)
    endif

    if activity == PickZoneA then
        at_end_action_pickzonea(bound_tokens)
    endif

    if activity == PickZoneB then
        at_end_action_pickzoneb(bound_tokens)
    endif

    if activity == Label then
        at_end_action_label(bound_tokens)
    endif

    if activity == Scan then
        at_end_action_scan(bound_tokens)
    endif

    if activity == Pack then
        at_end_action_pack(bound_tokens)
    endif

    if activity == Release then
        at_end_action_release(bound_tokens)
    endif

endrule

// -----------------------------------------------------------------------------
// Run Routine (removed - phases now controlled by main rule)
// -----------------------------------------------------------------------------

// =============================================================================
// INITIAL STATE
// =============================================================================

init:
    // Create constant objects (Queues and Activities)
    C1 := new Queue
    C2 := new Queue
    C3 := new Queue
    C4 := new Queue
    Q1 := new Queue
    Q2 := new Queue
    Q3 := new Queue
    Q4 := new Queue
    Q5 := new Queue
    Q6 := new Queue
    S1 := new Queue
    S2 := new Queue
    S3 := new Queue
    S4 := new Queue
    S5 := new Queue
    S6 := new Queue
    Jobs := new Queue
    CreateZA1 := new Activity
    CreateZA2 := new Activity
    CreateZB1 := new Activity
    CreateZB2 := new Activity
    PickZoneA := new Activity
    PickZoneB := new Activity
    Label := new Activity
    Scan := new Activity
    Pack := new Activity
    Release := new Activity

    // M/M/n configuration (must be set before markings that depend on it)
    Q1_max := 30
    Q2_max := 20
    Q3_max := 50
    Q4_max := 20
    Q5_max := 30
    Q6_max := 20
    S1_capacity := 4
    S2_capacity := 2
    S3_capacity := 3
    S4_capacity := 1
    S5_capacity := 3
    S6_capacity := 2
    iat_c1_mean := 2.0
    iat_c2_mean := 3.0
    iat_c3_mean := 4.0
    iat_c4_mean := 5.0
    ist_s1_mean := 3.0
    ist_s2_mean := 4.0
    ist_s3_mean := 1.5
    ist_s4_mean := 0.5
    ist_s5_mean := 2.0
    ist_s6_mean := 1.0
    sim_end_time := 1000.0

    // Initialize markings (matching EG initial state: 0 busy, 0 in queue)
    marking(C1) := 1
    marking(C2) := 1
    marking(C3) := 1
    marking(C4) := 1
    marking(Q1) := 0
    marking(Q2) := 0
    marking(Q3) := 0
    marking(Q4) := 0
    marking(Q5) := 0
    marking(Q6) := 0
    marking(S1) := 4
    marking(S2) := 2
    marking(S3) := 3
    marking(S4) := 1
    marking(S5) := 3
    marking(S6) := 2
    marking(Jobs) := 0

    // Initialize token lists
    tokens(C1) := []
    tokens(C2) := []
    tokens(C3) := []
    tokens(C4) := []
    tokens(Q1) := []
    tokens(Q2) := []
    tokens(Q3) := []
    tokens(Q4) := []
    tokens(Q5) := []
    tokens(Q6) := []
    tokens(S1) := []
    tokens(S2) := []
    tokens(S3) := []
    tokens(S4) := []
    tokens(S5) := []
    tokens(S6) := []
    tokens(Jobs) := []

    // Simulation bounds
    sim_clocktime := 0.0
    job_id_counter := 0
    departure_count := 0
    total_sojourn_time := 0.0
    total_time_in_queue := 0.0

    // Initialize FEL
    future_event_list := []

    // Scanning flag and phase control
    activities_started := false
    current_phase := "scan"
endinit

// =============================================================================
// MAIN RULE
// =============================================================================

main rule main =
    // Initialize tokens on first step (tokens(C1) is empty until initialisation_routine runs)
    if sim_clocktime == 0.0 and lib.length(tokens(C1)) == 0 then
        initialisation_routine()
        current_phase := "scan"
    endif

    // Run while time not exceeded
    if sim_clocktime < sim_end_time then
        if current_phase == "scan" then
            scanning_phase_single()
            // Switch to timing only if no activity could start
            if not activities_started then
                current_phase := "time"
            endif
        else
            // current_phase == "time"
            if lib.length(future_event_list) > 0 then
                timing_phase()
            endif
            current_phase := "scan"
        endif
    endif
endrule
